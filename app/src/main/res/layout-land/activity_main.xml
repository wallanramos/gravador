<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.grav.FuturisticBackgroundView
        android:id="@+id/backgroundView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingLeft="40dp"
        android:paddingRight="40dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Left Column: Timer, Status, Waveform -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="64sp"
                android:fontFamily="sans-serif-light" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Pronto"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.2" />

            <com.grav.WaveformView
                android:id="@+id/waveformView"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginTop="24dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp" />

        </LinearLayout>

        <!-- Right Column: Controls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginLeft="32dp">

            <!-- Recordings Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Gravações"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecordings"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="12dp" />

            <!-- Gain Control -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GANHO"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:minWidth="48dp" />

                <SeekBar
                    android:id="@+id/seekBarGain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="400"
                    android:progress="100"
                    android:progressTint="#FFFFFF"
                    android:thumbTint="#FFFFFF" />

                <TextView
                    android:id="@+id/tvGainValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0x"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:minWidth="36dp"
                    android:gravity="end" />

            </LinearLayout>

            <!-- Output Device -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAÍDA"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:minWidth="48dp" />

                <Button
                    android:id="@+id/btnOutputDevice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:text="Padrão (automático)"
                    android:textColor="#FFFFFFFF"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:gravity="end|center_vertical"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:minHeight="0dp" />

            </LinearLayout>

            <!-- Main Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnRecord"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/btn_record"
                    android:text="REC"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnMonitor"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/btn_monitor"
                    android:text="MONITOR"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnEq"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/btn_monitor"
                    android:text="EQ"
                    android:textColor="#FFFFD700"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
